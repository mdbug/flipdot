# flipdot configuration — copy to .env and uncomment what you need.
# Every value shown is the built-in default; the app runs with no .env at all.
# On the device, .env lives at /home/flipdot/flipdot/.env and is never touched
# by deploy.sh (rsync excludes it).

# ── Core ─────────────────────────────────────────────────────────────────────
#CAMERA_INDEX=0                 # /dev/video<N>
#PREVIEW=false                  # true = pygame preview window instead of the serial panel
#DEBUG=false                    # overlay distance/angle debug text on the bottom rows
#LOG_LEVEL=INFO                 # DEBUG for per-second performance logs
#SLEEP_HOUR_START=0             # nightly sleep window (mode: sleep)
#SLEEP_HOUR_END=7
#FOCAL_SCALE=1.0                # camera focal-length fudge factor for distance estimation

# ── Web UI ───────────────────────────────────────────────────────────────────
#ENABLE_WEB_UI=false            # browser console on http://<host>:<port>
#WEB_UI_HOST=127.0.0.1          # 0.0.0.0 to expose on the LAN (trusted networks only)
#WEB_UI_PORT=8000
#WEB_UI_ALLOWED_ORIGINS=        # extra CORS origins, comma-separated

# ── AI chat & MCP ────────────────────────────────────────────────────────────
# The in-UI chat needs at least one provider key; models without a key show as
# unavailable. The external /mcp endpoint stays disabled until MCP_AUTH_TOKEN
# is set, even with ENABLE_MCP=true.
#ANTHROPIC_API_KEY=
#ANTHROPIC_MODEL=claude-opus-4-8
#OPENAI_API_KEY=
#OPENROUTER_API_KEY=
#ENABLE_MCP=true
#MCP_AUTH_TOKEN=                # bearer token for external MCP clients
#MCP_ALLOWED_HOSTS=             # extra Host header values, comma-separated

# ── Bluetooth controllers ────────────────────────────────────────────────────
# Unset = controllers disabled. Use the *bonded* address from pairing (these
# IINE pads regenerate their address on every re-pair — see docs/jetson-setup.md).
#PRIMARY_CONTROLLER_ADDRESS=AA:BB:CC:DD:EE:01
#PRIMARY_CONTROLLER_NAME=IINE_keyboard
#SECONDARY_CONTROLLER_ADDRESS=AA:BB:CC:DD:EE:02
# BLE link tuning applied after each connect (helps weak pads ride through fades):
#CONTROLLER_SUPERVISION_TIMEOUT_MS=2000   # 0 disables the LE Connection Update
#CONTROLLER_CONN_MIN_INTERVAL_MS=15
#CONTROLLER_CONN_MAX_INTERVAL_MS=30

# ── Integrations ─────────────────────────────────────────────────────────────
#OPENWEATHER_API_KEY=           # weather on the clock face (openweathermap.org)
#WEATHER_CITY=Berlin
#WEATHER_COUNTRY_CODE=DE
#API_FOOTBALL_API_KEY=          # worldcup mode (api-football.com)

# ── Pose / vision models ─────────────────────────────────────────────────────
#MEDIAPIPE_MODELS_DIR=          # default: <repo>/models
#POSE_MODEL=pose_landmarker_lite   # or pose_landmarker_heavy (used in production)
#FACE_MESH_MAX_FPS=12
#HAIR_SEGMENT_MAX_FPS=7
# (Many more fine-grained figure/gesture tuning knobs exist — grep for os.getenv
#  in app/services/figure.py, app/services/human_pose.py, app/core/transition_policy.py.)

# ── Script sandbox ───────────────────────────────────────────────────────────
#SANDBOX_MEM_MB=1024
#SANDBOX_CPU_SECONDS=600
#SANDBOX_NPROC=256
#SANDBOX_FRAME_TIMEOUT=0.25     # seconds per frame
#SANDBOX_STARTUP_TIMEOUT=8.0
#SANDBOX_MAX_SOURCE_BYTES=262144
